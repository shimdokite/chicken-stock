generator client {
  provider      = "prisma-client"
  output        = "../generated/prisma"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum EducationSummaryLabel {
  BEGINNER // 초급
  INTERMEDIATE // 중급
  ADVANCED // 고급
}

enum Quiz_type {
  MULTIPLE_CHOICE // 객관식
  TRUE_FALSE // O/X
  SHORT_ANSWER // 주관식
}

enum InvestmentType {
  AGGRESSIVE // 공격투자형
  ACTIVE // 적극투자형
  BALANCED // 위험중립형
  CONSERVATIVE // 안정추구형
  STABLE // 안정형
}

enum UserType {
  NORMAL // 일반 사용자
  AGENT // 에이전트 사용자

  @@map("User_type")
}

enum TradeOrderType {
  BUY  @map("매수") // 매수
  SELL @map("매도") // 매도

  @@map("Trade_order_type")
}

enum TradeOrderStatus {
  PENDING // 대기
  COMPLETED // 완료
  CANCELED // 취소

  @@map("Trade_order_status")
}

enum OrderBookSide {
  ASK @map("매도") // 매도 호가
  BID @map("매수") // 매수 호가

  @@map("Order_book_side")
}

enum CurrencyCode {
  KRW // 원화
  USD // 미국 달러

  @@map("Currency_code")
}

enum DividendStatus {
  EXPECTED @map("expected") // 예상
  PENDING  @map("pending") // 대기
  RECEIVED @map("received") // 수령 완료

  @@map("Dividend_status")
}

enum TransactionType {
  BUY        @map("buy") // 매수
  SELL       @map("sell") // 매도
  EXCHANGE   @map("exchange") // 환전
  DEPOSIT    @map("deposit") // 입금
  WITHDRAWAL @map("withdrawal") // 출금
  DIVIDEND   @map("dividend") // 배당

  @@map("Transaction_type")
}

enum AgentType {
  AGGRESSIVE // 공격형
  CONSERVATIVE // 보수형
  GROWTH // 성장형
  MOMENTUM // 모멘텀형
  VALUE // 가치형
  FX_FOCUSED // 환율 집중형

  @@map("Agent_type")
}

enum DecisionSource {
  ADK // Google ADK 판단
  RULE_BASED // 규칙 기반 판단

  @@map("Decision_source")
}

enum TradeSide {
  BUY // 매수
  SELL // 매도
  HOLD // 보류

  @@map("Trade_side")
}

enum DecisionStatus {
  PENDING // 대기
  EXECUTED // 실행 완료
  REJECTED // 거절
  FAILED // 실패
  SKIPPED // 주문 없이 건너뜀

  @@map("Decision_status")
}

enum TradeFrequency {
  LOW // 낮음
  MEDIUM // 보통
  HIGH // 높음

  @@map("Trade_frequency")
}

enum StockSector {
  TECH // 기술
  BIO // 바이오
  FINANCE // 금융
  CONSUMER // 소비재

  @@map("Stock_sector")
}

enum StockRiskLevel {
  LOW // 낮음
  MEDIUM // 보통
  HIGH // 높음

  @@map("Stock_risk_level")
}

enum StockTheme {
  AI // 인공지능
  SEMICONDUCTOR // 반도체
  CLOUD // 클라우드
  PHARMACEUTICAL // 제약
  MEDICAL_DEVICE // 의료기기
  HEALTHCARE_SERVICE // 헬스케어 서비스
  BANKING // 은행
  SECURITIES // 증권
  PAYMENT // 결제
  E_COMMERCE // 전자상거래
  FOOD_BEVERAGE // 식음료
  CONTENT // 콘텐츠

  @@map("Stock_theme")
}

enum StockMarketStatus {
  LISTED // 상장
  IPO // 기업공개
  PRE_LISTING // 상장 전

  @@map("Stock_market_status")
}

model User {
  id                 BigInt                  @id @default(autoincrement())
  type               UserType                @default(NORMAL)
  name               String                  @default("") @db.VarChar(255)
  email              String?                 @unique @db.VarChar(255)
  investmentType     InvestmentType?         @map("investment_type")
  profileImageUrl    String?                 @map("profile_image_url") @db.VarChar(2048)
  currentLevel       Int?                    @default(1) @map("current_level")
  currentStep        Int?                    @default(1) @map("current_step")
  totalSteps         Int?                    @default(0) @map("total_steps")
  createdAt          DateTime                @default(now()) @map("created_at")
  updatedAt          DateTime                @updatedAt @map("updated_at")
  refreshTokens      RefreshToken[]
  articleCompletions UserArticleCompletion[]
  agent              Agent?
  portfolio          Portfolio?

  @@index([email])
  @@map("User")
}

model RefreshToken {
  id        BigInt    @id @default(autoincrement())
  userId    BigInt    @map("user_id")
  tokenHash String    @unique @map("token_hash")
  userAgent String?   @map("user_agent")
  ipAddress String?   @map("ip_address")
  expiresAt DateTime  @map("expires_at")
  revokedAt DateTime? @map("revoked_at")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("RefreshToken")
}

model Article {
  id                 Int                     @id @default(autoincrement())
  educationSummaryId Int                     @map("education_summary_id")
  educationSummary   EducationSummary        @relation(fields: [educationSummaryId], references: [id])
  quizzes            Quiz[]
  title              String
  content            String
  imageUrl           String                  @map("image_url")
  sortOrder          Int                     @default(0) @map("sort_order")
  createdAt          DateTime                @default(now()) @map("created_at")
  updatedAt          DateTime                @updatedAt @map("updated_at")
  completions        UserArticleCompletion[]

  @@index([educationSummaryId])
}

model Quiz {
  id               Int                  @id @default(autoincrement())
  educationLevelId Int                  @map("education_level_id")
  educationLevel   EducationSummary     @relation(fields: [educationLevelId], references: [stage])
  articleId        Int                  @map("article_id")
  article          Article              @relation(fields: [articleId], references: [id])
  quizType         Quiz_type            @map("quiz_type")
  question         String               @db.VarChar(255)
  description      String               @db.Text
  answer           String               @db.Text
  explanation      String               @db.Text
  optionText       String[]             @map("option_text") @db.VarChar(255)
  createdAt        DateTime             @default(now()) @map("created_at")
  updatedAt        DateTime             @updatedAt @map("updated_at")
  submissions      UserQuizSubmission[]

  @@index([educationLevelId])
  @@index([articleId])
}

model UserQuizSubmission {
  userId         BigInt    @map("user_id")
  quizId         Int       @map("quiz_id")
  quiz           Quiz      @relation(fields: [quizId], references: [id])
  selectedAnswer String    @map("selected_answer") @db.Text
  isSkip         Boolean   @map("is_skip")
  isCorrect      Boolean   @map("is_correct")
  answeredAt     DateTime? @map("answered_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  @@id([userId, quizId])
  @@map("User_quiz_submission")
}

model EducationSummary {
  id        Int                          @id @default(autoincrement())
  stage     Int                          @unique
  label     EducationSummaryLabel
  title     String                       @default("")
  imageUrl  String                       @map("image_url")
  summary   String[]
  createdAt DateTime                     @default(now()) @map("created_at")
  updatedAt DateTime                     @updatedAt @map("updated_at")
  articles  Article[]
  quizzes   Quiz[]
  progress  UserEducationLevelProgress[]

  @@map("Education_summary")
}

model UserEducationLevelProgress {
  userId           BigInt           @map("user_id")
  educationLevelId Int              @map("education_level_id")
  educationLevel   EducationSummary @relation(fields: [educationLevelId], references: [stage])
  isLocked         Boolean          @map("is_locked")
  progressRate     Int              @map("progress_rate")
  currentStep      Int              @map("current_step")
  totalSteps       Int              @map("total_steps")
  startedAt        DateTime         @map("started_at")
  completedAt      DateTime         @map("completed_at")
  createdAt        DateTime         @default(now()) @map("created_at")
  updatedAt        DateTime         @updatedAt @map("updated_at")

  @@id([userId, educationLevelId])
  @@map("User_education_level_progress")
}

model UserArticleCompletion {
  userId       BigInt    @map("user_id")
  articleId    Int       @map("article_id")
  user         User      @relation(fields: [userId], references: [id])
  article      Article   @relation(fields: [articleId], references: [id])
  progressRate Int       @default(0) @map("progress_rate")
  isCompleted  Boolean   @default(false) @map("is_completed")
  completedAt  DateTime? @map("completed_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  @@id([userId, articleId])
  @@map("User_article_completion")
}

enum StatementType {
  INCOME_STATEMENT
  BALANCE_SHEET
  CASH_FLOW

  @@map("Statement_type")
}

enum PeriodType {
  ANNUAL
  QUARTER

  @@map("Period_type")
}

model Agent {
  userId           BigInt             @id @map("user_id")
  agentType        AgentType          @map("agent_type")
  riskTolerance    Decimal            @map("risk_tolerance")
  maxPositionRatio Decimal            @map("max_position_ratio")
  cashReserveRatio Decimal            @map("cash_reserve_ratio")
  tradeFrequency   TradeFrequency     @map("trade_frequency")
  isActive         Boolean            @map("is_active")
  createdAt        DateTime           @default(now()) @map("created_at")
  updatedAt        DateTime           @updatedAt @map("updated_at")
  user             User               @relation(fields: [userId], references: [id])
  sectors          AgentStockSector[]
  decisionLogs     AgentDecisionLog[]

  @@map("Agent")
}

model AgentStockSector {
  userId BigInt      @map("user_id")
  sector StockSector
  agent  Agent       @relation(fields: [userId], references: [userId])

  @@id([userId, sector])
  @@map("Agent_stock_sector")
}

model Portfolio {
  id                        BigInt                 @id @default(autoincrement())
  accountNumber             String                 @unique @map("account_number") @db.VarChar(255)
  userId                    BigInt                 @unique @map("user_id")
  totalBalance              Decimal                @default(0) @map("total_balance") @db.Decimal(20, 2)
  krwBalance                Decimal                @default(0) @map("krw_balance") @db.Decimal(20, 2)
  usdBalance                Decimal                @default(0) @map("usd_balance") @db.Decimal(20, 2)
  totalAvailableOrderAmount Decimal                @default(0) @map("total_available_order_amount") @db.Decimal(20, 2)
  totalInvestmentAmount     Decimal                @default(0) @map("total_investment_amount") @db.Decimal(20, 2)
  domesticStockAmount       Decimal                @default(0) @map("domestic_stock_amount") @db.Decimal(20, 2)
  foreignStockAmount        Decimal                @default(0) @map("foreign_stock_amount") @db.Decimal(20, 2)
  createdAt                 DateTime               @default(now()) @map("created_at")
  updatedAt                 DateTime               @updatedAt @map("updated_at")
  user                      User                   @relation(fields: [userId], references: [id])
  items                     PortfolioItem[]
  tradeOrders               TradeOrder[]
  transactions              PortfolioTransaction[]
  dividends                 PortfolioDividend[]

  @@map("Portfolio")
}

model PortfolioTransaction {
  id              String              @id @default(cuid()) @db.VarChar(255)
  portfolioId     BigInt              @map("portfolio_id")
  stockId         Int?                @map("stock_id")
  tradeOrderId    BigInt?             @map("trade_order_id")
  executedAt      DateTime            @map("executed_at") @db.Date
  companyName     String              @map("company_name") @db.VarChar(255)
  transactionType TransactionType     @map("transaction_type")
  totalAmount     Decimal             @map("total_amount") @db.Decimal(20, 2)
  totalQuantity   Int                 @map("total_quantity")
  purchaseAmount  Decimal?            @map("purchase_amount") @db.Decimal(20, 2)
  realizedProfit  Decimal?            @map("realized_profit") @db.Decimal(20, 2)
  withdrawalAt    DateTime            @map("withdrawal_at") @db.Date
  fee             Decimal             @default(0) @db.Decimal(20, 2)
  exchangeType    String?             @map("exchange_type") @db.VarChar(16)
  paidAmount      Decimal?            @map("paid_amount") @db.Decimal(20, 2)
  receivedAmount  Decimal?            @map("received_amount") @db.Decimal(20, 2)
  exchangeRate    Decimal?            @map("exchange_rate") @db.Decimal(20, 4)
  createdAt       DateTime            @default(now()) @map("created_at")
  updatedAt       DateTime            @updatedAt @map("updated_at")
  portfolio       Portfolio           @relation(fields: [portfolioId], references: [id])
  stock           Stock?              @relation(fields: [stockId], references: [id])
  tradeOrder      TradeOrder?         @relation(fields: [tradeOrderId], references: [orderId])
  dividends       PortfolioDividend[]

  @@index([portfolioId])
  @@index([stockId])
  @@index([tradeOrderId])
  @@map("Portfolio_transaction")
}

model PortfolioItem {
  portfolioId      BigInt    @map("portfolio_id")
  stockId          Int       @map("stock_id")
  assetType        String    @map("asset_type") @db.VarChar(255)
  companyName      String    @map("company_name") @db.VarChar(255)
  companyLogoUrl   String    @map("company_logo_url") @db.VarChar(2048)
  quantity         Int       @default(0)
  averagePrice     Decimal   @default(0) @map("average_price") @db.Decimal(20, 2)
  currentPrice     Decimal   @default(0) @map("current_price") @db.Decimal(20, 2)
  totalInvested    Decimal   @default(0) @map("total_invested") @db.Decimal(20, 2)
  currentAmount    Decimal   @default(0) @map("current_amount") @db.Decimal(20, 2)
  evaluationAmount Decimal   @default(0) @map("evaluation_amount") @db.Decimal(20, 2)
  profit           Decimal   @default(0) @db.Decimal(20, 2)
  profitRate       Decimal   @default(0) @map("profit_rate") @db.Decimal(10, 4)
  fee              Decimal   @default(0) @db.Decimal(20, 2)
  saleTax          Decimal   @default(0) @map("sale_tax") @db.Decimal(20, 2)
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")
  portfolio        Portfolio @relation(fields: [portfolioId], references: [id])
  stock            Stock     @relation(fields: [stockId], references: [id])

  @@id([portfolioId, stockId])
  @@map("Portfolio_item")
}

model DividendEvent {
  id              String              @id @db.VarChar(255)
  stockId         Int                 @map("stock_id")
  paymentDate     DateTime            @map("payment_date") @db.Date
  recordDate      DateTime            @map("record_date") @db.Date
  dividendExDate  DateTime            @map("dividend_ex_date") @db.Date
  amountPerShare  Decimal             @map("amount_per_share")
  currencyCode    CurrencyCode        @map("currency_code")
  createdAt       DateTime            @default(now()) @map("created_at")
  updatedAt       DateTime            @updatedAt @map("updated_at")
  stock           Stock               @relation(fields: [stockId], references: [id])
  portfolioEvents PortfolioDividend[]

  @@map("Dividend_event")
}

model PortfolioDividend {
  id                     String               @id @db.VarChar(255)
  portfolioId            BigInt               @map("portfolio_id")
  dividendEventId        String               @map("dividend_event_id") @db.VarChar(255)
  portfolioTransactionId String               @map("portfolio_transaction_id") @db.VarChar(255)
  quantity               Int
  dividendAmount         Decimal              @map("dividend_amount")
  dividendStatus         DividendStatus       @map("dividend_status")
  createdAt              DateTime             @default(now()) @map("created_at")
  updatedAt              DateTime             @updatedAt @map("updated_at")
  portfolio              Portfolio            @relation(fields: [portfolioId], references: [id])
  dividendEvent          DividendEvent        @relation(fields: [dividendEventId], references: [id])
  portfolioTransaction   PortfolioTransaction @relation(fields: [portfolioTransactionId], references: [id])

  @@map("Portfolio_dividend")
}

model Stock {
  id                       Int                       @id
  ticker                   String                    @unique @db.VarChar(255)
  name                     String                    @db.VarChar(255)
  imageUrl                 String                    @map("image_url") @db.VarChar(255)
  sector                   StockSector
  riskLevel                StockRiskLevel            @map("risk_level")
  theme                    StockTheme
  countryCode              String                    @map("country_code") @db.VarChar(255)
  currencyCode             CurrencyCode              @map("currency_code")
  currentPrice             Decimal                   @map("current_price")
  previousClose            Decimal                   @map("previous_close")
  changeAmount             Decimal                   @map("change_amount")
  changeRate               Decimal                   @map("change_rate")
  dayHigh                  Decimal                   @map("day_high")
  dayLow                   Decimal                   @map("day_low")
  high52w                  Decimal                   @map("high_52w")
  low52w                   Decimal                   @map("low_52w")
  volume                   Decimal
  tradingValue             Decimal                   @map("trading_value")
  marketCap                Decimal                   @map("market_cap")
  per                      Decimal
  eps                      Decimal
  marketStatus             StockMarketStatus         @map("market_status")
  debtRatio                Decimal                   @map("debt_ratio")
  currentRatio             Decimal                   @map("current_ratio")
  interestCoverageRatio    Decimal                   @map("interest_coverage_ratio")
  announcementDate         DateTime                  @map("announcement_date") @db.Date
  estimatedOperatingProfit String                    @map("estimated_operating_profit") @db.VarChar(255)
  estimatedRevenue         Decimal                   @map("estimated_revenue")
  dividendCount            Int                       @map("dividend_count")
  dividendPerShare         Decimal                   @map("dividend_per_share")
  dividendYield            Decimal                   @map("dividend_yield")
  createdAt                DateTime                  @default(now()) @map("created_at")
  updatedAt                DateTime                  @updatedAt @map("updated_at")
  portfolioItems           PortfolioItem[]
  tradeOrders              TradeOrder[]
  tradeExecutions          TradeExecution[]
  transactions             PortfolioTransaction[]
  dividendEvents           DividendEvent[]
  candles                  StockCandle[]
  orderBookSnapshots       OrderBookSnapshot[]
  financialMetric          StockFinancialMetric?
  financialStatements      StockFinancialStatement[]
  earnings                 StockEarning[]
  agentDecisionLogs        AgentDecisionLog[]

  @@map("Stock")
}

model StockFinancialMetric {
  id                    String   @id @default(cuid()) @db.VarChar(255)
  stockId               Int      @unique @map("stock_id")
  stock                 Stock    @relation(fields: [stockId], references: [id], onDelete: Cascade)
  debtRatio             Float?   @map("debt_ratio")
  currentRatio          Float?   @map("current_ratio")
  interestCoverageRatio Float?   @map("interest_coverage_ratio")
  per                   Float?
  pbr                   Float?
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  @@map("Stock_financial_metric")
}

model StockFinancialStatement {
  id            String        @id @default(cuid()) @db.VarChar(255)
  stockId       Int           @map("stock_id")
  stock         Stock         @relation(fields: [stockId], references: [id], onDelete: Cascade)
  statementType StatementType @map("statement_type")
  periodType    PeriodType    @map("period_type")
  fiscalYear    Int           @map("fiscal_year")
  fiscalQuarter Int?          @map("fiscal_quarter")
  data          Json
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  @@unique([stockId, statementType, periodType, fiscalYear, fiscalQuarter], map: "Stock_financial_statement_stock_id_statement_type_period_type_f")
  @@map("Stock_financial_statement")
}

model StockEarning {
  id                       String     @id @default(cuid()) @db.VarChar(255)
  stockId                  Int        @map("stock_id")
  stock                    Stock      @relation(fields: [stockId], references: [id], onDelete: Cascade)
  announcementDate         DateTime?  @map("announcement_date")
  periodType               PeriodType @map("period_type")
  fiscalYear               Int        @map("fiscal_year")
  fiscalQuarter            Int?       @map("fiscal_quarter")
  estimatedRevenue         BigInt?    @map("estimated_revenue")
  estimatedOperatingProfit BigInt?    @map("estimated_operating_profit")
  createdAt                DateTime   @default(now()) @map("created_at")
  updatedAt                DateTime   @updatedAt @map("updated_at")

  @@unique([stockId, periodType, fiscalYear, fiscalQuarter], map: "Stock_earning_stock_id_period_type_fiscal_year_fiscal_quarter_k")
  @@map("Stock_earning")
}

model TradeOrder {
  orderId           BigInt                 @id @map("order_id")
  portfolioId       BigInt                 @map("portfolio_id")
  stockId           Int                    @map("stock_id")
  ticker            String                 @db.VarChar(255)
  type              TradeOrderType
  quantity          Int
  pricePerShare     Decimal                @map("price_per_share")
  status            TradeOrderStatus
  orderedAt         DateTime               @map("ordered_at")
  filledQuantity    Int                    @map("filled_quantity")
  remainingQuantity Int                    @map("remaining_quantity")
  executedPrice     Decimal?               @map("executed_price")
  executedAt        DateTime?              @map("executed_at")
  canceledAt        DateTime?              @map("canceled_at")
  rejectReason      String?                @map("reject_reason") @db.VarChar(255)
  currencyCode      CurrencyCode           @map("currency_code")
  createdAt         DateTime               @default(now()) @map("created_at")
  updatedAt         DateTime               @updatedAt @map("updated_at")
  portfolio         Portfolio              @relation(fields: [portfolioId], references: [id])
  stock             Stock                  @relation(fields: [stockId], references: [id])
  transactions      PortfolioTransaction[]
  buyExecutions     TradeExecution[]       @relation("BuyTradeExecutions")
  sellExecutions    TradeExecution[]       @relation("SellTradeExecutions")
  agentDecisionLogs AgentDecisionLog[]

  @@map("Trade_order")
}

model AgentDecisionLog {
  id              BigInt         @id @default(autoincrement())
  agentUserId     BigInt         @map("agent_user_id")
  stockId         Int            @map("stock_id")
  agentType       AgentType      @map("agent_type")
  decisionSource  DecisionSource @map("decision_source")
  side            TradeSide
  quantity        Int
  reason          String         @db.Text
  score           Decimal        @db.Decimal(10, 4)
  rawResponse     Json           @map("raw_response")
  status          DecisionStatus
  rejectReason    String?        @map("reject_reason") @db.Text
  executedOrderId BigInt?        @map("executed_order_id")
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")
  agent           Agent          @relation(fields: [agentUserId], references: [userId])
  stock           Stock          @relation(fields: [stockId], references: [id])
  executedOrder   TradeOrder?    @relation(fields: [executedOrderId], references: [orderId])

  @@index([agentUserId])
  @@index([stockId])
  @@index([executedOrderId])
  @@map("Agent_decision_log")
}

model TradeExecution {
  id            String         @id @default(cuid()) @db.VarChar(255)
  stockId       Int            @map("stock_id")
  ticker        String         @db.VarChar(255)
  buyOrderId    BigInt?        @map("buy_order_id")
  sellOrderId   BigInt?        @map("sell_order_id")
  price         Decimal        @db.Decimal(20, 2)
  quantity      Int
  aggressorSide TradeOrderType @map("aggressor_side")
  executedAt    DateTime       @map("executed_at")
  createdAt     DateTime       @default(now()) @map("created_at")
  stock         Stock          @relation(fields: [stockId], references: [id])
  buyOrder      TradeOrder?    @relation("BuyTradeExecutions", fields: [buyOrderId], references: [orderId])
  sellOrder     TradeOrder?    @relation("SellTradeExecutions", fields: [sellOrderId], references: [orderId])

  @@index([stockId, executedAt])
  @@index([buyOrderId])
  @@index([sellOrderId])
  @@map("Trade_execution")
}

model StockCandle {
  ticker       String  @db.VarChar(255)
  intervalCode String  @map("interval_code") @db.VarChar(255)
  timestamp    BigInt
  openPrice    Decimal @map("open_price")
  highPrice    Decimal @map("high_price")
  lowPrice     Decimal @map("low_price")
  closePrice   Decimal @map("close_price")
  volume       Decimal
  stock        Stock   @relation(fields: [ticker], references: [ticker])

  @@id([ticker, intervalCode, timestamp])
  @@map("Stock_candle")
}

model OrderBookSnapshot {
  ticker            String           @db.VarChar(255)
  timestamp         BigInt
  totalAskSize      Decimal          @map("total_ask_size")
  totalBidSize      Decimal          @map("total_bid_size")
  volume            Decimal
  buyVolume         Decimal          @map("buy_volume")
  sellVolume        Decimal          @map("sell_volume")
  executionStrength Decimal          @map("execution_strength")
  lastTradeVolume   Decimal          @map("last_trade_volume")
  createdAt         DateTime         @default(now()) @map("created_at")
  stock             Stock            @relation(fields: [ticker], references: [ticker])
  levels            OrderBookLevel[]

  @@id([ticker, timestamp])
  @@map("Order_book_snapshot")
}

model OrderBookLevel {
  ticker            String            @db.VarChar(255)
  snapshotTimestamp BigInt            @map("snapshot_timestamp")
  side              OrderBookSide
  levelRank         Int               @map("level_rank")
  price             Decimal
  quantity          Decimal
  snapshot          OrderBookSnapshot @relation(fields: [ticker, snapshotTimestamp], references: [ticker, timestamp])

  @@id([ticker, snapshotTimestamp, side, levelRank])
  @@map("Order_book_level")
}

model MarketIndex {
  id            Int                 @id
  ticker        String              @unique @db.VarChar(255)
  name          String              @db.VarChar(255)
  indexType     String              @map("index_type") @db.VarChar(255)
  currentValue  Decimal             @map("current_value")
  previousClose Decimal             @map("previous_close")
  changeAmount  Decimal             @map("change_amount")
  changeRate    Decimal             @map("change_rate")
  isRealtime    Boolean             @map("is_realtime")
  provider      String              @db.VarChar(255)
  countryCode   String              @map("country_code") @db.VarChar(255)
  currencyCode  CurrencyCode        @map("currency_code")
  buyPrice      Decimal             @map("buy_price")
  sellPrice     Decimal             @map("sell_price")
  createdAt     DateTime            @default(now()) @map("created_at")
  updatedAt     DateTime            @updatedAt @map("updated_at")
  candles       MarketIndexCandle[]

  @@map("Market_index")
}

model MarketIndexCandle {
  ticker       String      @db.VarChar(255)
  intervalCode String      @map("interval_code") @db.VarChar(255)
  timestamp    BigInt
  openValue    Decimal     @map("open_value")
  highValue    Decimal     @map("high_value")
  lowValue     Decimal     @map("low_value")
  closeValue   Decimal     @map("close_value")
  volume       Decimal?
  marketIndex  MarketIndex @relation(fields: [ticker], references: [ticker])

  @@id([ticker, intervalCode, timestamp])
  @@map("Market_index_candle")
}
